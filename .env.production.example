APP_ENV=production
APP_USERNAME=admin
APP_PASSWORD=replace-with-strong-admin-password
SECRET_KEY=change-me-secret-key

FRONTEND_ORIGIN=https://thetrendscope.com
VITE_API_BASE=https://api.thetrendscope.com/api/v1

DATABASE_URL=postgresql://viral:change-me-postgres-password@pgbouncer:5432/viral_radar?sslmode=disable
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222

CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=viral_analytics
CLICKHOUSE_USER=viral
CLICKHOUSE_PASSWORD=replace-with-strong-password

YOUTUBE_API_KEY=change-me-youtube-api-key

# Future TikTok provider integration. Leave empty for go-live.
TIKTOK_API_KEY=
TIKTOK_API_BASE=

# Future Instagram provider integration. Leave empty for go-live.
INSTAGRAM_API_KEY=
INSTAGRAM_API_BASE=

REGIONS=FR,US,ES
THEMES=business,gaming,tech,lifestyle,finance
SCAN_INTERVAL_MINUTES=15

STRIPE_SECRET_KEY=change-me-stripe-secret-key
STRIPE_WEBHOOK_SECRET=change-me-stripe-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=change-me-stripe-price-pro
STRIPE_PRICE_STUDIO_MONTHLY=change-me-stripe-price-studio

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@thetrendscope.com
SMTP_TLS=true

POSTGRES_PASSWORD=change-me-strong

# Public domain
APP_DOMAIN=thetrendscope.com
APP_WWW_DOMAIN=www.thetrendscope.com
API_DOMAIN=api.thetrendscope.com
TRAEFIK_DOMAIN=traefik.thetrendscope.com
GRAFANA_DOMAIN=grafana.thetrendscope.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# Traefik / ACME
ACME_EMAIL=admin@thetrendscope.com
# Optional: use Let's Encrypt staging to avoid rate limits during tests.
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=

# Cloudflare DNS-01 token (scoped token, not Global API Key)
CF_DNS_API_TOKEN=change-me-cloudflare-dns-token

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Telegram alert delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

LOCAL_EXPORTS_DIR=exports


# Monitoring images
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
GRAFANA_IMAGE=grafana/grafana:11.4.0
LOKI_IMAGE=grafana/loki:3.3.2
PROMTAIL_IMAGE=grafana/promtail:3.3.2
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.8.2
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.49.1
BLACKBOX_EXPORTER_IMAGE=prom/blackbox-exporter:v0.25.0
CURL_IMAGE=curlimages/curl:8.10.1
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100
ALERTMANAGER_URL=http://alertmanager:9093
BLACKBOX_URL=http://blackbox:9115
NODE_EXPORTER_URL=http://node-exporter:9100
CADVISOR_URL=http://cadvisor:8080
