APP_ENV=production
APP_USERNAME=admin
APP_PASSWORD=replace-with-strong-admin-password
SECRET_KEY=replace-with-openssl-rand-hex-32

FRONTEND_ORIGIN=https://thetrendscope.com
VITE_API_BASE=https://api.thetrendscope.com/api/v1

DATABASE_URL=postgresql://viral:<strong-password>@pgbouncer:5432/viral_radar?sslmode=disable
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222

CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=viral_analytics
CLICKHOUSE_USER=viral
CLICKHOUSE_PASSWORD=replace-with-strong-password

YOUTUBE_API_KEY=replace-with-server-side-youtube-api-key

# Future TikTok provider integration. Leave empty for go-live.
TIKTOK_API_KEY=
TIKTOK_API_BASE=

# Future Instagram provider integration. Leave empty for go-live.
INSTAGRAM_API_KEY=
INSTAGRAM_API_BASE=

REGIONS=FR,US,ES
THEMES=business,gaming,tech,lifestyle,finance
SCAN_INTERVAL_MINUTES=15

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_STUDIO_MONTHLY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@thetrendscope.com
SMTP_TLS=true

POSTGRES_PASSWORD=change-me-strong

# Public domain
APP_DOMAIN=thetrendscope.com
APP_WWW_DOMAIN=www.thetrendscope.com
API_DOMAIN=api.thetrendscope.com
TRAEFIK_DOMAIN=traefik.thetrendscope.com

# Traefik / ACME
ACME_EMAIL=admin@thetrendscope.com
# Optional: use Let's Encrypt staging to avoid rate limits during tests.
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=

# Cloudflare DNS-01 token (scoped token, not Global API Key)
CF_DNS_API_TOKEN=replace-with-cloudflare-dns-token

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Telegram alert delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

LOCAL_EXPORTS_DIR=exports